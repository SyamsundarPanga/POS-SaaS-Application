            <stringProp name="DurationAssertion.duration">3000</stringProp>
          </DurationAssertion>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Log Login Details" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">
log.info(&quot;========================================&quot;)
log.info(&quot;Thread: &quot; + ctx.getThreadNum() + &quot; | Login SUCCESS&quot;)
log.info(&quot;  Email:    &quot; + vars.get(&quot;email&quot;))
log.info(&quot;  TenantID: &quot; + vars.get(&quot;tenantId&quot;))
log.info(&quot;  Store:    &quot; + vars.get(&quot;storeName&quot;))
log.info(&quot;  Token:    &quot; + vars.get(&quot;accessToken&quot;)?.take(30) + &quot;...&quot;)
log.info(&quot;  Expected: &quot; + vars.get(&quot;expectedTenantId&quot;))
log.info(&quot;========================================&quot;)
            </stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PostProcessor>
