          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Validate Token TenantId Match" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">
import groovy.json.JsonSlurper

def response = prev.getResponseDataAsString()
def expectedTenantId = vars.get(&quot;tenantId&quot;)

if (response == null || response.trim().isEmpty()) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&quot;Empty response from /api/auth/validate&quot;)
    return
}

try {
    def json = new JsonSlurper().parseText(response)
    def userInfo = json.userInfo ?: json.user ?: json
    def tokenTenantId = userInfo?.tenantId
    
    if (tokenTenantId != null &amp;&amp; tokenTenantId != expectedTenantId) {
        AssertionResult.setFailure(true)
        AssertionResult.setFailureMessage(
            &quot;TOKEN TENANT MISMATCH! &quot; +
            &quot;Expected: ${expectedTenantId}, &quot; +
            &quot;Got: ${tokenTenantId} — &quot; +
            &quot;This indicates a serious tenant context leak!&quot;
        )
    }
    
    log.info(&quot;Thread ${ctx.getThreadNum()} | Token Validate OK | TenantId: ${tokenTenantId}&quot;)
} catch (Exception e) {
    log.warn(&quot;Could not parse validate response: &quot; + e.message)
}
            </stringProp>
