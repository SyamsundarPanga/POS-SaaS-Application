            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">
import groovy.json.JsonSlurper

def response = prev.getResponseDataAsString()
def expectedTenantId = vars.get(&quot;tenantId&quot;)

if (response == null || response.trim().isEmpty()) {
    return
}

try {
    def json = new JsonSlurper().parseText(response)
    def content = json.content ?: json
    
    if (content instanceof List) {
        content.each { item -&gt;
            if (item.tenantId != null &amp;&amp; item.tenantId != expectedTenantId) {
                AssertionResult.setFailure(true)
                AssertionResult.setFailureMessage(
                    &quot;CROSS-TENANT DATA LEAKAGE DETECTED in Categories! &quot; +
                    &quot;Expected tenantId: ${expectedTenantId}, &quot; +
                    &quot;Found tenantId: ${item.tenantId} &quot; +
                    &quot;in category: ${item.name ?: item.id}&quot;
                )
            }
        }
    }
} catch (Exception e) {
    log.warn(&quot;Could not parse categories response for tenant check: &quot; + e.message)
}
